# load this file
alias aliases="vim ~/.zsh_aliases"

# restart zsh
alias zshr="echo 'Restarting ZSH...'; source ~/.zshrc; echo '[DONE]';";

# ebp ssh
alias ebpdev="echo 'Connecting to EBP...'; ssh -t lmsadmin@127.0.0.1 -p 5000 'cd /var/www; /usr/bin/zsh'"
alias autossh-start="echo 'Connecting to EBP...'; autossh -L localhost:5000:localhost:22 lmsadmin@151.106.38.236"

# convenience
alias zshc="vim ~/.zshrc"
alias vimc="vim ~/.vimrc"
alias tmuxc="vim ~/.tmux.conf"

# docker
alias dcu="docker-compose up -d --build"

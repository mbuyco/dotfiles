# load this file
alias als="vim ~/.zsh_aliases"

# restart zsh
alias zshr="echo 'Restarting ZSH...'; source ~/.zshrc; echo '[DONE]';";

# ebp ssh
alias ebpdev_ssh="ssh -t lmsadmin@127.0.0.1 -p 5000 'cd /var/www; /usr/bin/zsh'"
alias ebpdev="echo 'Connecting to EBP...'; autossh -L localhost:5000:localhost:22 lmsadmin@151.106.38.236 -V && ebpdev_ssh"

# convenience
alias zshc="vim ~/.zshrc"
alias vimc="vim ~/.vimrc"
alias tmuxc="vim ~/.tmux.conf"

# docker
alias dps="docker ps"
alias dr="docker run"
alias dsa="docker stop $(dps -q)"
alias dka="docker kill $(dps -q)"
alias drma="docker rm $(dps -a -q)"
alias drmi="docker rmi $(docker images -q)"

# docker-compose
alias dc="docker-compose"
alias dcu="dc up -d --build"
alias dcd="dc down"
alias dcr="dcd && dcu"
alias dcc="dc config"
alias dx="dc exec"
